        status.TextColor3 = Color3.fromRGB(150, 150, 150)
        status.Font = Enum.Font.GothamMedium
        status.TextSize = 12
        status.Parent = mainButton
        
        local subtitle = Instance.new("TextLabel")
        subtitle.Size = UDim2.new(1, 0, 0, 18)
        subtitle.BackgroundTransparency = 1
        subtitle.Text = "❄️ COLD STORM ❄️"
        subtitle.TextColor3 = Color3.fromRGB(100, 180, 220)
        subtitle.Font = Enum.Font.Gotham
        subtitle.TextSize = 10
        subtitle.Parent = mainButton
        
        local ice = Instance.new("TextLabel")
        ice.Size = UDim2.new(0, 45, 0, 22)
        ice.Position = UDim2.new(1, -50, 0, 8)
        ice.BackgroundColor3 = Color3.fromRGB(0, 120, 180)
        ice.BackgroundTransparency = 0.3
        ice.Text = "ICE"
        ice.TextColor3 = Color3.fromRGB(255, 255, 255)
        ice.Font = Enum.Font.GothamBold
        ice.TextSize = 11
        local iceCorner = Instance.new("UICorner")
        iceCorner.CornerRadius = UDim.new(0, 10)
        iceCorner.Parent = ice
        ice.Parent = mainButton
        
        -- Toggle Function
        mainButton.MouseButton1Click:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            
            active = not active
            
            if active then
                status.Text = "🔴 ACTIVE 🔴"
                status.TextColor3 = Color3.fromRGB(255, 50, 50)
                mainButton.BackgroundColor3 = Color3.fromRGB(40, 20, 30)
                mainButton.BorderColor3 = Color3.fromRGB(255, 0, 100)
                title.TextColor3 = Color3.fromRGB(255, 100, 150)
                subtitle.Text = "💀 ONE HIT MODE 💀"
                
                task.spawn(function()
                    while active do
                        local checkChar = LocalPlayer.Character
                        if not checkChar then break end
                        local checkHrp = checkChar:FindFirstChild("HumanoidRootPart")
                        if not checkHrp then break end
                        local pos = checkHrp.Position
                        checkHrp.CFrame = CFrame.new(pos.X, pos.Y - 795679695796326795679695796326, pos.Z)
                        task.wait(0.01)
                    end
                end)
            else
                status.Text = "⚡ READY ⚡"
                status.TextColor3 = Color3.fromRGB(150, 150, 150)
                mainButton.BackgroundColor3 = Color3.fromRGB(20, 30, 45)
                mainButton.BorderColor3 = Color3.fromRGB(0, 200, 255)
                title.TextColor3 = Color3.fromRGB(0, 230, 255)
                subtitle.Text = "❄️ COLD STORM ❄️"
            end
        end)
        
        -- DRAG SYSTEM
        local dragging = false
        local dragStart
        local startPos
        
        mainButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                dragStart = input.Position
                startPos = mainButton.Position
            end
        end)
        
        mainButton.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
                local delta = input.Position - dragStart
                mainButton.Position = UDim2.new(
                    startPos.X.Scale,
                    startPos.X.Offset + delta.X,
                    startPos.Y.Scale,
                    startPos.Y.Offset + delta.Y
                )
            end
        end)
        
        print("✅ KYIEL ONE HIT | Key Verified - Script Loaded")
    end
    
    -- Check key when submit button clicked
    submitBtn.MouseButton1Click:Connect(function()
        local enteredKey = keyBox.Text
        
        if enteredKey == requiredKey then
            loadMainScript()
        else
            errorMsg.Text = "❌ Invalid Key! Access Denied"
            keyBox.Text = ""
            keyBox.PlaceholderText = "Wrong key, try again..."
            
            -- Shake animation for wrong key
            local originalPos = keyFrame.Position
            for i = 1, 4 do
                keyFrame.Position = UDim2.new(0.5, -175 + (i % 2 == 0 and -10 or 10), 0.5, -100)
            task.wait(0.03)
            end
            keyFrame.Position = originalPos
        end
    end)
    
    -- Also allow pressing Enter in textbox
    keyBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local enteredKey = keyBox.Text
            if enteredKey == requiredKey then
                loadMainScript()
            else
                errorMsg.Text = "❌ Invalid Key! Access Denied"
                keyBox.Text = ""
            end
        end
    end)
    
    print("🔐 KYIEL ONE HIT | Waiting for key...")
