    -- MAIN BUTTON (hidden until key is correct)
    local mainButton = nil
    local mainGui = nil
    
    -- Function to load main script
    function loadMainScript()
        -- Destroy key GUI
        keyGui:Destroy()
        
        -- Create main GUI
        mainGui = Instance.new("ScreenGui")
        mainGui.ResetOnSpawn = false
        mainGui.Parent = game.CoreGui
        
        mainButton = Instance.new("TextButton")
        mainButton.Size = UDim2.new(0, 220, 0, 90)
        mainButton.Position = UDim2.new(0.5, -110, 0.5, -45)
        mainButton.BackgroundColor3 = Color3.fromRGB(20, 30, 45)
