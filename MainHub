-- KYIEL ONE HIT - DRAGGABLE BUTTON
-- Load with: loadstring(game:HttpGet("YOUR_URL"))()

(function()
    -- Protection
    if not game:GetService("Players").LocalPlayer then return end
    
    local Players = game:GetService("Players")
    local UserInputService = game:GetService("UserInputService")
    local LocalPlayer = Players.LocalPlayer
    local active = false
    
    -- GUI
    local screenGui = Instance.new("ScreenGui")
    screenGui.ResetOnSpawn = false
    screenGui.Parent = game.CoreGui
    
    -- Button
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 200, 0, 85)
    button.Position = UDim2.new(0.5, -100, 0.5, -42)
    button.BackgroundColor3 = Color3.fromRGB(20, 30, 45)
    button.BorderSizePixel = 2
    button.BorderColor3 = Color3.fromRGB(0, 200, 255)
    button.Text = ""
    button.Parent = screenGui
    
    -- Corner
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 25)
    corner.Parent = button
    
    -- Layout
    local layout = Instance.new("UIListLayout")
    layout.Parent = button
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Padding = UDim.new(0, 5)
    
    -- Title
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 35)
    title.BackgroundTransparency = 1
    title.Text = "KYIEL ONE HIT"
    title.TextColor3 = Color3.fromRGB(0, 230, 255)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 22
    title.Parent = button
    
    -- Status
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(1, 0, 0, 20)
    status.BackgroundTransparency = 1
    status.Text = "⚡ READY ⚡"
    status.TextColor3 = Color3.fromRGB(150, 150, 150)
    status.Font = Enum.Font.GothamMedium
    status.TextSize = 12
    status.Parent = button
    
    -- ICE Badge
    local ice = Instance.new("TextLabel")
    ice.Size = UDim2.new(0, 45, 0, 22)
    ice.Position = UDim2.new(1, -50, 0, 8)
    ice.BackgroundColor3 = Color3.fromRGB(0, 120, 180)
    ice.BackgroundTransparency = 0.3
    ice.Text = "ICE"
    ice.TextColor3 = Color3.fromRGB(255, 255, 255)
    ice.Font = Enum.Font.GothamBold
    ice.TextSize = 11
    local iceCorner = Instance.new("UICorner")
    iceCorner.CornerRadius = UDim.new(0, 10)
    iceCorner.Parent = ice
    ice.Parent = button
    
    -- Hidden Key
    local key = "F30995186908109077563811n4ek"
    button:SetAttribute("Key", key)
    
    -- Toggle
    button.MouseButton1Click:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        active = not active
        
        if active then
            status.Text = "🔴 ACTIVE 🔴"
            status.TextColor3 = Color3.fromRGB(255, 50, 50)
            button.BackgroundColor3 = Color3.fromRGB(40, 20, 30)
            button.BorderColor3 = Color3.fromRGB(255, 0, 100)
            title.TextColor3 = Color3.fromRGB(255, 100, 150)
            
            task.spawn(function()
                while active do
                    local checkChar = LocalPlayer.Character
                    if not checkChar then break end
                    local checkHrp = checkChar:FindFirstChild("HumanoidRootPart")
                    if not checkHrp then break end
                    local pos = checkHrp.Position
                    checkHrp.CFrame = CFrame.new(pos.X, pos.Y - 795679695796326795679695796326, pos.Z)
                    task.wait(0.01)
                end
            end)
        else
            status.Text = "⚡ READY ⚡"
            status.TextColor3 = Color3.fromRGB(150, 150, 150)
            button.BackgroundColor3 = Color3.fromRGB(20, 30, 45)
            button.BorderColor3 = Color3.fromRGB(0, 200, 255)
            title.TextColor3 = Color3.fromRGB(0, 230, 255)
        end
    end)
    
    -- DRAG SYSTEM
    local dragging = false
    local dragStart
    local startPos
    
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = button.Position
        end
    end)
    
    button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            button.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    print("KYIEL ONE HIT LOADED | Key: " .. key)
end)()
